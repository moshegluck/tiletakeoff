# ---- AI plan detection (server-side only; used by /api/detect-plan) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Optional override. Defaults to claude-sonnet-5 (vision-capable, high-res).
ANTHROPIC_MODEL=claude-sonnet-5

# ---- Rate limiting for /api/detect-plan (optional) ----
# Without these, the route rate-limits in-memory (per warm serverless
# instance). Set an Upstash Redis (or Vercel KV) REST endpoint for durable,
# cross-instance limiting. Either variable-name pair works.
# UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxx

# ---- Supabase cloud (optional; app runs local-only if omitted) ----
# Safe to expose: anon key is protected by Row Level Security.
# NOTE: when these are present, /api/detect-plan also REQUIRES a signed-in
# Supabase session (the route verifies the user's JWT) and rate-limits per
# user — so the Anthropic key can't be spent by anonymous callers. Without
# Supabase configured, the route runs open but rate-limits per IP.
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
